# Default all text files to Unix line endings (LF)
* text=auto eol=lf

# Patch files should always use Unix line endings (LF)
*.patch eol=lf diff=patch
*.diff eol=lf diff=patch

# Shell scripts should use Unix line endings
*.sh eol=lf
*.bash eol=lf
scripts/* text eol=lf

# Preserve line endings for binary files
*.tar.* binary
*.zip binary
*.exe binary
*.lnk binary
