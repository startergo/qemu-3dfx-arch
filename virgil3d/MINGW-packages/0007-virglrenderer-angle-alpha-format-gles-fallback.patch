diff --git a/src/vrend/vrend_formats.c b/src/vrend/vrend_formats.c
--- a/src/vrend/vrend_formats.c
+++ b/src/vrend/vrend_formats.c
@@ -536,12 +536,11 @@ void vrend_build_format_list_common(void)
 
   /* float support */
   add_formats(float_base_formats);
-  add_formats(la_formats_compat);
   add_formats(la_formats_fallback);
 
   add_formats(float_3comp_formats);
 
   /* texture integer support ? */
   add_formats(integer_base_formats);
 
   add_formats(integer_3comp_formats);
@@ -589,10 +589,17 @@ void vrend_build_format_list_gl(void)
 {
   add_formats(gl_z32_format);
   /* GL_BGRA formats aren't as well supported in GLES as in GL, specially in
    * transfer operations. So we only register support for it in GL.
    */
+  /* LA compat formats (GL_ALPHA8, GL_LUMINANCE8 etc.) are legacy OpenGL
+   * formats. On GLES their pixel transfer format (GL_ALPHA/GL_LUMINANCE)
+   * is not valid for glTexSubImage2D, causing silent upload failures and
+   * blank/invisible text glyphs. Use la_formats_fallback (GL_R8 + swizzle)
+   * for GLES instead by registering la_formats_compat only on desktop GL.
+   */
+  add_formats(la_formats_compat);
   add_formats(gl_base_rgba_formats);
   add_formats(gl_bgra_formats);
   add_formats(gl_bit10_formats);
